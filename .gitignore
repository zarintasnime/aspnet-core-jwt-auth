## .NET / Visual Studio .gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results for every project subfolder
**/[Dd]ebug/
**/[Dd]ebugPublic/
**/[Rr]elease/
**/[Rr]eleases/
**/[Bb]in/
**/[Oo]bj/

# Rider / VS Code
.idea/
.vscode/

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# ASP.NET Core user secrets & local env files
appsettings.*.local.json
*.env
.env

# Uploaded runtime files (keep the folder, ignore uploaded content)
wwwroot/Pictures/

# OS files
.DS_Store
Thumbs.db

# Others
*.pdb
*.cache
*.log
